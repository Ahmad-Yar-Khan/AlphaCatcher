   661                                  ; a function to generate random number between 0 and n
   662                                  ; input: n, can be accessed using bp+4
   663                                  ; output: random number can be accessed in function using bp+6
   664                                  RANDNUM:
   665 000004FA 55                         push bp
   666 000004FB 89E5                       mov bp,sp
   667 000004FD 50                         push ax
   668 000004FE 51                         push cx
   669 000004FF 52                         push dx
   670                                     
   671 00000500 B400                       MOV AH, 00h  ; interrupts to get system time        
   672 00000502 CD1A                       INT 1AH      ; CX:DX now hold number of clock ticks since midnight      
   673 00000504 89D0                       mov  ax, dx
   674 00000506 31D2                       xor  dx, dx
   675 00000508 8B4E04                     mov  cx, [bp+4] 
   676 0000050B 41                         inc cx   
   677 0000050C F7F1                       div  cx       ; here dx contains the remainder of the division - from 0 to 9
   678 0000050E 895606                     mov [bp+6], dx
   679 00000511 5A                         pop dx
   680 00000512 59                         pop cx
   681 00000513 58                         pop ax
   682 00000514 5D                         pop bp   
   683 00000515 C20200                     ret 2
   684                                     
   685                                  generateAlpha:
   686 00000518 55                          push bp
   687 00000519 89E5                        mov bp, sp
   688 0000051B 50                          push ax
   689 0000051C 51                          push cx
   690 0000051D 52                          push dx
   691                                  
   692                                      ; Get system time for randomness
   693 0000051E B400                        mov ah, 00h
   694 00000520 CD1A                        int 1ah      ; CX:DX holds the number of clock ticks since midnight
   695 00000522 89D0                        mov ax, dx   ; Move DX (the random seed) into AX
   696 00000524 31D2                        xor dx, dx
   697 00000526 8B4E04                      mov cx, [bp+4]  
   698 00000529 41                          inc cx
   699 0000052A F7F1                        div cx          
   700                                  
   701 0000052C 83C241                      add dx, 41h     ; Convert 0-25 to ASCII 'A'-'Z' (41h is ASCII for 'A')
   702                                  
   703 0000052F 895606                      mov [bp+6], dx  ; Store the result in the output location
   704 00000532 5A                          pop dx
   705 00000533 59                          pop cx
   706 00000534 58                          pop ax
   707 00000535 5D                          pop bp
   708 00000536 C20200                      ret 2   	; Return and clean up the stack
   709                                  	
   710                                  	
   711                                  calculatetimer:
   712 00000539 FF06[6D01]              inc word[timertick]
   713                                  
   714 0000053D 833E[6D01]0F            cmp word[timertick], 15
   715 00000542 751D                    jne endtimer
   716                                  
   717 00000544 C706[6D01]0000          mov word[timertick],0
   718 0000054A FF06[7101]              inc word[secs]
   719                                  
   720                                  
   721 0000054E 833E[7101]3B            cmp word[secs],59
   722 00000553 7302                    jae incmin
   723                                  
   724                                  
   725 00000555 EB0A                    jmp endtimer
   726                                  incmin:
   727 00000557 C706[7101]0000          mov word[secs],0
   728 0000055D FF06[6F01]              inc word[mins]
   729                                  
   730                                  endtimer:
   731 00000561 C3                      ret
   732                                  printStopWatch:
