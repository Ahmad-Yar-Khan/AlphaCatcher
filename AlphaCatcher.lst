   100                                  printNumber:
   101 00000173 55                          push bp
   102 00000174 89E5                        mov bp, sp
   103 00000176 06                          push es
   104 00000177 50                          push ax
   105 00000178 53                          push bx
   106 00000179 51                          push cx
   107 0000017A 52                          push dx
   108 0000017B 57                          push di
   109 0000017C 6800B8                  	push 0xb800
   110 0000017F 07                      	pop es
   111 00000180 8B4604                      mov ax, [bp+4] ; load number in ax
   112 00000183 BB0A00                      mov bx, 10 ; use base 10 for division
   113 00000186 B90000                      mov cx, 0 ; initialize count of digits
   114                                  	
   115                                  nextDigit:
   116 00000189 BA0000                      mov dx, 0 ; zero upper half of dividend
   117 0000018C F7F3                        div bx ; divide by 10
   118 0000018E 80C230                      add dl, 0x30 ; convert digit into ascii value
   119 00000191 52                          push dx ; save ascii value on stack
   120 00000192 41                          inc cx ; increment count of values
   121 00000193 83F800                      cmp ax, 0 ; is the quotient zero
   122 00000196 75F1                        jnz nextDigit ; if no divide it again
   123 00000198 8B7E06                      mov di, [bp+6] ; point di to 70th column
   124                                  	
   125                                  nextPosition:
   126 0000019B 5A                          pop dx ; remove a digit from the stack
   127 0000019C B607                        mov dh, 0x07 ; use normal attribute
   128 0000019E 268915                      mov [es:di], dx ; print char on screen
   129 000001A1 83C702                      add di, 2 ; move to next screen location
   130 000001A4 E2F5                        loop nextPosition ; repeat for all digits on stack
   131 000001A6 5F                          pop di
   132 000001A7 5A                          pop dx
   133 000001A8 59                          pop cx
   134 000001A9 5B                          pop bx
   135 000001AA 58                          pop ax
   136 000001AB 07                          pop es
   137 000001AC 5D                          pop bp
   138 000001AD C20400                      ret 4
   139                                  
   140                                  printstr:
   141 000001B0 55                      	push bp
   142 000001B1 89E5                    	  mov  bp, sp 
   143 000001B3 06                      	  push es 
   144 000001B4 50                      	  push ax 
   145 000001B5 51                      	  push cx 
   146 000001B6 56                      	  push si 
   147 000001B7 57                      	  push di 
   148                                  
   149 000001B8 1E                      	  push ds  
   150 000001B9 07                      	  pop  es                 ; load ds in es 
   151 000001BA 8B7E04                  	  mov  di, [bp+4]         ; point di to string 
   152 000001BD B9FFFF                  	  mov  cx, 0xffff         ; load maximum number in cx 
   153 000001C0 30C0                    	  xor  al, al             ; load a zero in al 
   154 000001C2 F2AE                    	  repne scasb             ; find zero in the string 
   155 000001C4 B8FFFF                  	  mov  ax, 0xffff         ; load maximum number in ax 
   156 000001C7 29C8                    	  sub  ax, cx             ; find change in cx 
   157 000001C9 48                      	  dec  ax                 ; exclude null from length 
   158 000001CA 741E                    	  jz   exit               ; no printing if string is empty
   159                                  
   160 000001CC 89C1                    	  mov  cx, ax             ; load string length in cx 
   161 000001CE B800B8                  	  mov  ax, 0xb800 
   162 000001D1 8EC0                    	  mov  es, ax             ; point es to video base 
   163 000001D3 B050                    	  mov  al, 80             ; load al with columns per row 
   164 000001D5 F66608                  	  mul  byte [bp+8]        ; multiply with y position 
   165 000001D8 03460A                  	  add  ax, [bp+10]        ; add x position 
   166 000001DB D1E0                    	  shl  ax, 1              ; turn into byte offset 
   167 000001DD 89C7                    	  mov  di,ax              ; point di to required location 
   168 000001DF 8B7604                  	  mov  si, [bp+4]         ; point si to string 
   169 000001E2 8A6606                  	  mov  ah, [bp+6]         ; load attribute in ah 
   170                                  
   171 000001E5 FC                      	  cld                     ; auto increment mode 
   172 000001E6 AC                      nextchar:     lodsb                   ; load next char in al 
   173 000001E7 AB                      	  stosw                   ; print char/attribute pair 
   174 000001E8 E2FC                    	  loop nextchar           ; repeat for the whole string 
   175                                  
   176 000001EA 5F                      exit:         pop  di 
   177 000001EB 5E                      	  pop  si 
   178 000001EC 59                      	  pop  cx 
   179 000001ED 58                      	  pop  ax 
   180 000001EE 07                      	  pop  es 
   181 000001EF 5D                      	  pop  bp 
   182 000001F0 C20800                  	  ret  8
